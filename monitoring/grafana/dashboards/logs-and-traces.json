{
  "uid": "chessriend-logs-traces",
  "title": "Chessriend - Logs & Traces",
  "tags": ["spring-boot", "chessriend", "loki", "tempo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "level",
        "type": "custom",
        "current": {
          "text": "All",
          "value": ""
        },
        "options": [
          { "text": "All", "value": "", "selected": true },
          { "text": "ERROR", "value": "ERROR", "selected": false },
          { "text": "WARN", "value": "WARN", "selected": false },
          { "text": "INFO", "value": "INFO", "selected": false },
          { "text": "DEBUG", "value": "DEBUG", "selected": false }
        ],
        "query": "ERROR,WARN,INFO,DEBUG",
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({application=\"chessriend\"} [$__auto]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "WARN" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "INFO" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({application=\"chessriend\", level=\"ERROR\"} [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 3,
      "title": "Warn Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({application=\"chessriend\", level=\"WARN\"} [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "title": "Trace Count (Tempo)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(traces_spanmetrics_calls_total{service=\"chessriend\"}[$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 5,
      "title": "Avg Trace Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(traces_spanmetrics_latency_bucket{service=\"chessriend\"}[$__rate_interval])) by (le)) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "N/A"
        }
      },
      "options": {
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 6,
      "title": "Application Logs",
      "type": "logs",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{application=\"chessriend\"} ${level:pipe}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 7,
      "title": "Recent Traces",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "tag": "service.name",
              "operator": "=",
              "value": ["chessriend"],
              "scope": "resource"
            }
          ],
          "limit": 20,
          "refId": "A"
        }
      ]
    }
  ]
}
