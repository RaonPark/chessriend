{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "process_uptime_seconds{application=\"chessriend\"}",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "system_cpu_usage{application=\"chessriend\"}",
          "legendFormat": "system"
        },
        {
          "expr": "process_cpu_usage{application=\"chessriend\"}",
          "legendFormat": "process"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"chessriend\", area=\"heap\"}",
          "legendFormat": "used - {{id}}"
        },
        {
          "expr": "jvm_memory_committed_bytes{application=\"chessriend\", area=\"heap\"}",
          "legendFormat": "committed - {{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "title": "JVM Non-Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"chessriend\", area=\"nonheap\"}",
          "legendFormat": "used - {{id}}"
        },
        {
          "expr": "jvm_memory_committed_bytes{application=\"chessriend\", area=\"nonheap\"}",
          "legendFormat": "committed - {{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"chessriend\"}",
          "legendFormat": "live"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"chessriend\"}",
          "legendFormat": "daemon"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"chessriend\"}",
          "legendFormat": "peak"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"chessriend\"}[1m])",
          "legendFormat": "{{method}} {{uri}} [{{status}}]"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "title": "HTTP Response Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{application=\"chessriend\"}[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"chessriend\"}[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"chessriend\"}[1m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "GC Pause Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"chessriend\"}[1m])",
          "legendFormat": "{{action}} - {{cause}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "r2dbc_pool_acquired_connections{application=\"chessriend\"}",
          "legendFormat": "acquired"
        },
        {
          "expr": "r2dbc_pool_idle_connections{application=\"chessriend\"}",
          "legendFormat": "idle"
        },
        {
          "expr": "r2dbc_pool_max_allocated_connections{application=\"chessriend\"}",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["spring-boot", "chessriend"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Chessriend - Spring Boot Overview",
  "uid": "chessriend-overview"
}
