{
  "permissions": {
    "allow": [
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot"
    ]
  },
  "mcpServers": {
    "postgresql": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://chessriend:chessriend@localhost:5432/chessriend"
      ]
    },
    "serena": {
      "command": "/Users/raonpark/.local/bin/uvx",
      "args": [
        "--python",
        "3.13",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project",
        "/Users/raonpark/chessriend"
      ]
    }
  }
}
